{
  "name": "mytickets",
  "version": "1.0.0",
  "description": "Projeto base da API do MyTickets",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run migration:run && npm run seed && node dist/src/index.js",
    "migration:run": "prisma migrate deploy",
    "dev": "ts-node-dev src/server.ts",
    "test": "dotenv -e .env.test -- cross-env NODE_ENV=test jest --runInBand",
    "test:watch": "dotenv -e .env.test -- cross-env NODE_ENV=test jest --watchAll",
    "test:coverage": "dotenv -e .env.test -- cross-env NODE_ENV=test jest --coverage",
    "prisma:migrate:test": "dotenv -e .env.test -- prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "^9.6.0",
    "@prisma/client": "^6.5.0",
    "dotenv": "^16.4.7",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "faker": "^6.6.6",
    "http-status": "^1.7.4",
    "joi": "^17.13.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^8.0.0",
    "jest": "^29.7.0",
    "prisma": "^6.5.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}
